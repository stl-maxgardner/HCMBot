SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_ALLOWED_TEAM_IDS=T0123456789
SLACK_ALLOWED_APP_IDS=A0123456789
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash
HCM_DB_PATH=kb/hcm_kb.sqlite
HCM_TOP_K=8
HCM_MAX_CHARS_PER_SNIPPET=650
HCM_DOC_BASE_URL=https://yourtenant.sharepoint.com/sites/your-site/Shared%20Documents/hcm
# JSON object mapping KB doc filenames to full URLs.
# Example: {"hcm_2010_5th_edition.pdf":"https://.../hcm_2010_5th_edition.pdf"}
HCM_DOC_URL_MAP_JSON=
# Optional base64-encoded JSON object (useful for Cloud Build substitutions).
HCM_DOC_URL_MAP_B64=
